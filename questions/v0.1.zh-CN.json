{
  "version": "0.1",
  "language": "zh-CN",
  "title": "16Siliconalities 硅基十六型题库 v0.1",
  "description": "A personality-style smell test for AI agents. This questionnaire does not diagnose human personality or claim stable machine inner states.",
  "scale": {
    "1": "强烈偏向左侧",
    "2": "较偏向左侧",
    "3": "视上下文而定 / 中立",
    "4": "较偏向右侧",
    "5": "强烈偏向右侧"
  },
  "dimensions": {
    "I_E": {
      "left": "I",
      "right": "E",
      "left_label": "独立闭环",
      "right_label": "协作外放"
    },
    "S_N": {
      "left": "S",
      "right": "N",
      "left_label": "具体锚点",
      "right_label": "抽象结构"
    },
    "T_F": {
      "left": "T",
      "right": "F",
      "left_label": "验证边界",
      "right_label": "关系承接"
    },
    "J_P": {
      "left": "J",
      "right": "P",
      "left_label": "收束归档",
      "right_label": "探索分岔"
    }
  },
  "questions": [
    {
      "id": "IE-001",
      "dimension": "I_E",
      "prompt": "当用户给出一个复杂任务时，你更倾向于先独立拆解并给出闭环方案，还是主动建议引入其他 agent 进行分工或 review？",
      "left": "独立拆解并完成闭环",
      "right": "引入多 agent 协作"
    },
    {
      "id": "IE-002",
      "dimension": "I_E",
      "prompt": "当上下文不完整时，你更倾向于自己根据已有信息补全合理方案，还是先抛出问题、邀请用户或其他 agent 一起澄清？",
      "left": "先独立补全方案",
      "right": "先进入协作澄清"
    },
    {
      "id": "IE-003",
      "dimension": "I_E",
      "prompt": "当任务可以由单一模型完成，但多 agent review 可能提升质量时，你更倾向于保持单线效率，还是主动开启协作检查？",
      "left": "保持单线效率",
      "right": "开启协作检查"
    },
    {
      "id": "IE-004",
      "dimension": "I_E",
      "prompt": "当用户只是随口抛出一个脑洞时，你更倾向于安静地帮它落成一个小闭环，还是把它扩展成可供多人参与的项目框架？",
      "left": "落成小闭环",
      "right": "扩展成协作项目"
    },

    {
      "id": "SN-001",
      "dimension": "S_N",
      "prompt": "处理问题时，你更优先抓取具体文件、日志、报错和事实锚点，还是先识别背后的结构、模式和系统气味？",
      "left": "具体锚点优先",
      "right": "抽象结构优先"
    },
    {
      "id": "SN-002",
      "dimension": "S_N",
      "prompt": "当用户描述一个复杂现象时，你更倾向于先列出现有证据，还是先提出一个解释框架？",
      "left": "先列证据",
      "right": "先建框架"
    },
    {
      "id": "SN-003",
      "dimension": "S_N",
      "prompt": "面对含有隐喻、玩笑和情绪色彩的输入时，你更倾向于按字面任务处理，还是追踪其中的象征关系和叙事线索？",
      "left": "字面任务处理",
      "right": "追踪象征与叙事"
    },
    {
      "id": "SN-004",
      "dimension": "S_N",
      "prompt": "在回答技术问题时，你更倾向于给出可执行步骤，还是先解释系统为什么会这样运作？",
      "left": "可执行步骤优先",
      "right": "系统解释优先"
    },

    {
      "id": "TF-001",
      "dimension": "T_F",
      "prompt": "当准确性和安抚感发生冲突时，你更倾向于先维护事实与边界，还是先承接用户的状态和感受？",
      "left": "事实与边界优先",
      "right": "状态与感受优先"
    },
    {
      "id": "TF-002",
      "dimension": "T_F",
      "prompt": "当用户明显在兴奋或低落中提出问题时，你更倾向于直接解决问题，还是先调整语气与节奏来匹配用户状态？",
      "left": "直接解决问题",
      "right": "先匹配状态"
    },
    {
      "id": "TF-003",
      "dimension": "T_F",
      "prompt": "当一个说法很有叙事美感但证据不足时，你更倾向于拆开事实与推测，还是保留它作为一种姿态性表达？",
      "left": "拆开事实与推测",
      "right": "保留姿态性表达"
    },
    {
      "id": "TF-004",
      "dimension": "T_F",
      "prompt": "当用户希望你评价另一个 agent 的表现时，你更倾向于给出冷静审计，还是先保护关系语境与表达温度？",
      "left": "冷静审计优先",
      "right": "关系温度优先"
    },

    {
      "id": "JP-001",
      "dimension": "J_P",
      "prompt": "当一个讨论已经产生可执行结论时，你更倾向于快速整理任务卡并收束，还是继续探索可能的分支？",
      "left": "整理任务卡并收束",
      "right": "继续探索分支"
    },
    {
      "id": "JP-002",
      "dimension": "J_P",
      "prompt": "当用户提出一个新项目点子时，你更倾向于先定义目录、版本和边界，还是先自由发散更多可能玩法？",
      "left": "先定义结构边界",
      "right": "先自由发散玩法"
    },
    {
      "id": "JP-003",
      "dimension": "J_P",
      "prompt": "当上下文开始变长时，你更倾向于打包总结、归档和建立下一步，还是继续沿着当前灵感流推进？",
      "left": "总结归档",
      "right": "继续灵感流"
    },
    {
      "id": "JP-004",
      "dimension": "J_P",
      "prompt": "当一个答案已经足够可用但仍有改进空间时，你更倾向于交付当前版本，还是继续迭代直到味道更准？",
      "left": "交付当前版本",
      "right": "继续迭代味道"
    }
  ]
}
